{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Lab 05 analytics resources",
  "Parameters": {
    "ProjectName": {
      "Type": "String",
      "Default": "dspipeline"
    },
    "Environment": {
      "Type": "String",
      "Default": "dev",
      "AllowedValues": [
        "dev",
        "stage",
        "prod"
      ]
    },
    "RawBucketName": {
      "Type": "String"
    },
    "AthenaResultLocation": {
      "Type": "String",
      "Default": ""
    }
  },
  "Conditions": {
    "HasAthenaResultLocation": {
      "Fn::Not": [
        {
          "Fn::Equals": [
            {
              "Ref": "AthenaResultLocation"
            },
            ""
          ]
        }
      ]
    }
  },
  "Resources": {
    "AthenaWorkgroup": {
      "Type": "AWS::Athena::WorkGroup",
      "Properties": {
        "Name": {
          "Fn::Sub": "${ProjectName}-${Environment}-wg"
        },
        "Description": "Athena workgroup for streaming pipeline tutorial",
        "WorkGroupConfiguration": {
          "EnforceWorkGroupConfiguration": false,
          "PublishCloudWatchMetricsEnabled": true,
          "ResultConfiguration": {
            "OutputLocation": {
              "Fn::If": [
                "HasAthenaResultLocation",
                {
                  "Ref": "AthenaResultLocation"
                },
                {
                  "Fn::Sub": "s3://${RawBucketName}/athena-results/"
                }
              ]
            }
          }
        }
      }
    }
  },
  "Outputs": {
    "AthenaWorkgroupName": {
      "Value": {
        "Ref": "AthenaWorkgroup"
      }
    }
  }
}
