{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Lab 01 foundation resources",
  "Parameters": {
    "ProjectName": {
      "Type": "String",
      "Default": "dspipeline"
    },
    "Environment": {
      "Type": "String",
      "Default": "dev",
      "AllowedValues": [
        "dev",
        "stage",
        "prod"
      ]
    }
  },
  "Resources": {
    "RawBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "${ProjectName}-${Environment}-${AWS::AccountId}-${AWS::Region}-raw"
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      }
    },
    "EventStream": {
      "Type": "AWS::Kinesis::Stream",
      "Properties": {
        "Name": {
          "Fn::Sub": "${ProjectName}-${Environment}-events"
        },
        "ShardCount": 1,
        "RetentionPeriodHours": 24
      }
    },
    "CdcTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Fn::Sub": "${ProjectName}-${Environment}-orders"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "pk",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "pk",
            "KeyType": "HASH"
          }
        ],
        "StreamSpecification": {
          "StreamViewType": "NEW_AND_OLD_IMAGES"
        }
      }
    }
  },
  "Outputs": {
    "RawBucketName": {
      "Value": {
        "Ref": "RawBucket"
      }
    },
    "RawBucketArn": {
      "Value": {
        "Fn::GetAtt": [
          "RawBucket",
          "Arn"
        ]
      }
    },
    "StreamName": {
      "Value": {
        "Ref": "EventStream"
      }
    },
    "StreamArn": {
      "Value": {
        "Fn::GetAtt": [
          "EventStream",
          "Arn"
        ]
      }
    },
    "CdcTableName": {
      "Value": {
        "Ref": "CdcTable"
      }
    },
    "CdcTableStreamArn": {
      "Value": {
        "Fn::GetAtt": [
          "CdcTable",
          "StreamArn"
        ]
      }
    }
  }
}
